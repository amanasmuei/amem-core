{
  "name": "@aman_asmuei/amem-core",
  "version": "0.4.2",
  "description": "Core memory library for AI tools — database, embeddings, scoring, retrieval",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:quick": "tsx bench/quick-recall.ts",
    "bench:longmemeval": "tsx bench/longmemeval/run.ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.0",
    "better-sqlite3": "^12.0.0",
    "hnswlib-node": "^3.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Aman Asmuei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amanasmuei/amem.git",
    "directory": "amem-core"
  }
}
